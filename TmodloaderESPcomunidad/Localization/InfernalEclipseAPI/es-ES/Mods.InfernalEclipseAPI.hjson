	Lycanroc: {
		DisplayName: Lycanroc
		Tooltip: ""

		Progression: {
			WoF:
				'''
				Derrota al guardián del Infierno para obtener más poder...
				No se ha obtenido potencia adicional...
				'''
			Mechs:
				'''
				Con la derrota del Muro de Carne, las balas disparadas por esta arma infligen desmoronamiento
				Derrota a las bestias mecánicas para obtener más poder...
				'''
			Plantera:
				'''
				Tras la derrota de las máquinas de Draedon, esta arma ahora convierte las balas normales en balas de alta velocidad
				Derrota al guardián de la jungla para obtener más poder...
				'''
			Golem:
				'''
				Tras la derrota de Plantera, tu furia ahora hace que esta arma dispare increíblemente rápido
				Derrota la construcción del Templo de Lizhard para obtener más poder...
				'''
			Cultist:
				'''
				Con la derrota del Golem, tu adrenalina garantiza golpes críticos.
				Derrota al líder del antiguo culto para obtener más poder...
				'''
			MoonLord:
				'''
				Con la derrota del Cultista Lunático, esta arma ahora tiene la posibilidad de realizar un supercrítico
				Derrota al cadáver arcano para obtener más poder...
				'''
			Full: ¡El Lycanroc ha despertado por completo y ha desatado todo su poder!
		}

		Lore: "'¿Qué vas a hacer? ¿Matarme?'"
	}

	CelestialIllumination: {
		DisplayName: Iluminación celestial
		Tooltip: ""

		Progression: {
			Deus:
				'''
				Derrota al horror cósmico para obtener más poder...
				No se ha obtenido potencia adicional...
				'''
			MoonLord:
				'''
				Con la derrota del Señor de la Luna, tus estrellas son más rápidas
				Defeat the guardians of the profaned flame to gain more power...
				'''
			Providence:
				'''
				Con la derrota de Providence, tus ataques infligen Llamas Sagradas
				Derrota a los centinelas de la plaga para obtener más poder...
				'''
			Polterghast:
				'''
				Tras la derrota de Polterghast, podrás disparar un rayo celestial
				Derrota al Devorador de Dioses para obtener más poder...
				'''
			DoG:
				'''
				Con la derrota del Devorador de Dioses, tu hogar estelar
				Derrota al resplandeciente fénix para obtener más poder...
				'''
			Full: ¡La Iluminación Celestial ha despertado por completo y su verdadero poder ha sido revelado!
		}

		Lore: El último libro forjado por aquel que lleva la marca de Astra...
	}


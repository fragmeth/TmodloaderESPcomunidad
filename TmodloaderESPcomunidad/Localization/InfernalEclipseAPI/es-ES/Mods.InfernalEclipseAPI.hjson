DiaryTooltip:
	'''
	[c/E3AF40:Un misterioso diario que ha quedado sin firmar...]
	[c/BEBEBE:Pulsa la tecla "Shift izquierdo" para abrir el diario]
	'''
BullyingTooltip:
	'''
	Aumenta la mayoría del daño que no proviene de invocaciones en un 2% por cada espacio de esbirro no utilizado
	Reduce el daño de invocación en un 10% por cada espacio de esbirro utilizado
	Los látigos ahora escalan con tus bonificaciones de combate cuerpo a cuerpo en lugar de con las bonificaciones de invocador
	Aumenta el daño del látigo en un 10%
	[c/E3AF40:Un billete de papel con un microchip incorporado, diseñado por Dylan]
	[c/BEBEBE:Pulsa la tecla "Mayús izquierda" para leer el texto que aparece en el reverso de la nota]
	'''

Configs: {
	InfernalConfig: {
		WrathoftheGodsBossesInBossRush: {
			Tooltip: Añade a XG-07 Marte, el Avatar del Vacío y la Deidad Sin Nombre a la Oleada de Jefes
			Label: Los jefes de la ira de los Dioses en Boss Rush
		}

		BetsyInBossRush: {
			Tooltip: Añade a Betsy a Boss Rush - ACTUALMENTE TIENE UN ERROR
			Label: Betsy en Boss Rush
		}

		DreadnautillusInBossRush: {
			Tooltip: Añade a Dreadnautillus a el Bosss Rush
			Label: Dreadnautillus en Boss Rush
		}

		Headers: {
			BossRushChanges: Interruptores de Boss Rush
			BalanceChanges: Cambios de equilibrio
			Miscellaneous: Misceláneas
			MultiplayerAdjustments: Ajustes y utilidades multijugador
			Main: Principal
			Secret: Configuración Secreta
		}

		ThoriumBalanceChangess: {
			Tooltip: Modifica el torio y varios complementos de torio para que estén en sintonía con el equilibrio de Calamity
			Label: Cambios en el equilibrio de Thorium
		}

		CalamityRecipeTweaks: {
			Tooltip: Modifica algunas recetas de Calamity y elimina la mayoría de las recetas de Vanilla QOL
			Label: Ajustes en la receta de Calamity
		}

		CalamityBalanceChanges: {
			Tooltip:
				'''
				Modifica Calamity y varios complementos de Calamity que estén desequilibrados o con un nivel de poder demasiado bajo
				También ajusta algunas recetas de diferentes mods para mantener el equilibrio
				'''
			Label: Cambios de Balance de Calamity
		}

		BossKillCheckOnOres: {
			Tooltip:
				'''
				Realiza cambios en ciertos objetos para que no se puedan obtener hasta alcanzar su nivel previsto
				Impide la extracción de ciertos minerales y bloques hasta que derrotes a ciertos jefes
				'''
			Label: Mantener la progresión del nivel de calamidad
		}

		VanillaBalanceChanges: {
			Tooltip: Modifica algunos elementos del juego base para que estén en sintonía con el equilibrio de Calamity
			Label: Cambios en el equilibrio de vainilla
		}

		DisplayName: Configuración principal

		TerraBladeBossInBossRush: {
			Tooltip: Añade al jefe Terra Blade en el Boss Rush
			Label: Jefe Terra Blade en Boss Rush
		}

		InfernumModeForced: {
			Tooltip:
				'''
				Bloquea el control deslizante de dificultad de Calamidad, incluso fuera de las peleas contra jefes
				Asegúrese de establecer la dificultad antes de habilitar esta configuración
				Útil para servidores donde no se desea que se cambie la dificultad
				'''
			Label: Control deslizante de dificultad de calamidad bloqueado
		}

		SOTSBalanceChanges: {
			Tooltip: Modifica los objetos de Secretos de las Sombras para que estén en sintonía con el equilibrio de Calamity
			Label: Cambios de equilibrio de Secrets of the Shadows
		}

		ConsolariaBalanceChanges: {
			Tooltip: Modifica los objetos de Consolaria para que estén en sintonía con el equilibrio de Calamity
			Label: Cambios de equilibrio de Consolaria
		}

		InfernumRecipeTweaks: {
			Tooltip: Ajusta algunas recetas de Infernum
			Label: Modificaciones de recetas de Infernum
		}

		ForceFullXerocDialogue: {
			Label: Diálogo de Xeroc completo forzado
			Tooltip: Obliga al juego a mostrar el diálogo completo de Xeroc al iniciar el modo Boss Rush y al completarlo. Útil para los servidores
		}

		SOTSThrowerToRogue: {
			Tooltip: Crea los objetos de vacío + lanzador de los objetos de vacío + rogue de bardo, lanzador y sanador no oficiales de SOTS
			Label: Combina las clases Vacío + Lanzador y Rogue
		}

		DisableBloodOrbPotions: {
			Tooltip: Deshabilita las recetas de elaboración de pociones que utilizan orbes de sangre.
			Label: Desactivar pociones con orbe de sangre
		}

		PreventBossCheese: {
			Tooltip: Añade algunas mecánicas al juego que impiden que ciertos jefes sean derrotados fácilmente de determinadas maneras
			Label: Evitar exploits de jefes
		}

		DisableUnfinisedContent: {
			Label: Deshabilitar contenido no finalizado
			Tooltip: Deshabilita cualquier contenido inacabado de los mods para mantener una experiencia de juego consistente
		}

		DisableDuplicateContent: {
			Label: Deshabilitar contenido duplicado
			Tooltip: Deshabilita cualquier contenido duplicado que dos mods puedan agregar
		}

		AdditonalVanillaBossAdjustments: {
			Label: Ajustes adicionales para jefes Vanilla
			Tooltip: Ajusta ligeramente las estadísticas de algunos jefes del juego base para que supongan un mayor desafío
		}

		MergeCraftingTrees: {
			Label: Combinar árboles de creación
			Tooltip: Combina los árboles de creación de objetos similares de varios mods y añade materiales de creación de diferentes mods a ciertos objetos
		}

		BloodOrbPotionDuplication: {
			Label: Poción de orbe de sangre Duplication
			Tooltip: Sustituye las recetas de pociones de Orbe de Sangre por recetas de duplicación
		}

		ChanageWeaponClasses: {
			Label: Cambiar clases de armas
			Tooltip: Cambia la clase de algunas armas para ofrecer más variedad o para que tengan más sentido en relación con el arma
		}

		DisplayWorldEntryMessages: {
			Label: Mostrar mensajes de entrada al mundo
			Tooltip: Activa/desactiva los mensajes al entrar en un mundo
		}

		EnableInterlude4: {
			Label: Habilitar Interludio 4
			Tooltip:
				'''
				Activa/desactiva el tema del cuarto interludio
				Este interludio se reproducirá después de que tanto los Exo Mechs como las Calamitas Supremas hayan sido derrotados
				Esta canción reemplazará a Their Fabricator & Acceptance cuando suene
				'''
		}

		AdjustAdvisorSpawnConditions: {
			Label: Ajustar las condiciones de aparición del asesor
			Tooltip:
				'''
				Ajusta las condiciones de aparición del Asesor para que no esté siempre activo en el mundo
				Resulta útil si utilizas la barra de jefe Infernum y no quieres que esté siempre activa debido a que el Asesor está vivo todo el tiempo
				Se sabe que esto causa problemas en el modo multijugador, así que desactívalo si planeas jugar en modo multijugador
				'''
		}

		MultiplayerBossRespawnTimer: {
			Label: Temporizador de reaparición de jefes en el modo multijugador
			Tooltip: Cuánto tiempo se tarda en reaparecer durante una pelea contra un jefe
		}

		MinimumDifficultyToPreventRespawns: {
			Label: Dificultad mínima para evitar reapariciones
			Tooltip: La dificultad mínima para aplicar el sistema de prevención de reaparición
		}

		MultiplayerRespawnsAllowed: {
			Label: Se permiten reapariciones en el modo multijugador
			Tooltip: El número de reapariciones permitidas durante las batallas contra jefes
		}

		NerfThoriumMulticlass: {
			Label: Nerf Multiclase de Thorium
			Tooltip: Añade algunos sistemas para evitar que el Bardo y el Sanador se multiclasen y se vuelvan demasiado poderosos
		}

		ColoredRelics: {
			Label: Reliquias coloreadas
			Tooltip: Activa o desactiva los colores de las reliquias de este mod
		}

		ForceMenu: {
			Label: Tema del menú a la fuerza
			Tooltip: Obliga a que se seleccione el tema del menú "Infernal Eclipse of Ragnarok" al cargar el mod
		}

		AutomatedConfigSetup: {
			Label: Configuración automatizada
			Tooltip: Configura automáticamente los archivos de configuración de otros mods para que sean los archivos de configuración previstos para el paquete de mods Infernal Eclipse of Ragnarok
		}

		MoveDeerclopsChecklistEntry: {
			Label: Entrada de la lista de verificación de movimiento de Deerclops
			Tooltip: Mueve a Deerclops para que aparezca antes que Skeletron en la lista de jefes para que coincida con la posición de Calamity e Infernum en la clasificación
		}

		DontEnableThis: {
			Label: No habilite esto
			Tooltip: No actives esta opción. Probablemente te dará una idea equivocada y provocará un juego desequilibrado y defectuoso
		}

		CalamityExpertAccessories: {
			Label: Accesorios para expertos en calamidades
			Tooltip: Activa o desactiva la rareza de experto en ciertos objetos que sueltan los jefes de Calamity
		}

		AutomaticallyReforgeThoriumRogueItems: {
			Label: Reforja automáticamente los objetos de pícaro de Thorium
			Tooltip:
				'''
				Agrega automáticamente las bonificaciones de estadísticas del prefijo "Impecable" a todos los objetos de pícaro de torio no consumibles
				Puede ayudar a que los objetos de Torio alcancen el nivel de los objetos de Calamidad con prefijos, ya que los objetos de Pícaro de Torio no se pueden reforjar
				Solo funciona cuando Ragnarok o Unofficial Calamity Bard & Healer están activados
				Esta configuración no tiene efecto si la opción Fusionar Lanzador en Pícaro está habilitada
				'''
		}

		MergeThrowerIntoRogue: {
			Label: Fusionar lanzador en pícaro
			Tooltip:
				'''
				Fusiona las clases Lanzador y Pícaro en una sola clase mejorada
				Permite que las armas arrojadizas convertidas sigan recibiendo sus reforjas originales
				Además, mantiene intacto el escalado de daño de la barra de sigilo
				'''
		}

		ThereIsNoReasonDisableThis: {
			Label: No hay razón para deshabilitar esto
			Tooltip:
				'''
				No hay motivo para desactivar esta opción, ya que desactiva las dificultades que presentan errores y desequilibrios al combinarse con Infernum
				Desactive esta configuración únicamente si conoce las consecuencias y no informe de errores cuando esta configuración esté desactivada
				'''
		}
	}

